# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Database
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/db_shravann?sslmode=disable

# Encryption key for decrypting project API keys (hex-encoded 32 bytes, same as Go API)
ENCRYPTION_KEY=your_64_char_hex_string

# Provider API keys are loaded per-project from the database (configured via Settings page).
# No need to set OPENAI_API_KEY or GOOGLE_API_KEY here.