# API server
PORT=8080

# Postgres — copy to .env and set your password
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/db_shravann?sslmode=disable

# LiveKit (required for POST /agents/:id/sessions/start — create room + token)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Encryption key for API key storage (hex-encoded 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_string

# JWT secret for signing auth tokens (optional — random key generated if empty)
# Generate with: openssl rand -hex 32
JWT_SECRET=
